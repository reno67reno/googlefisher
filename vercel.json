{
  "functions": {
    "api/grab.js": {
      "maxDuration": 10
    },
    "api/config.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/grab",
      "destination": "/grab.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
